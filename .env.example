APP_NAME=EduCore API
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
LOG_LEVEL=info

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=educore
DATABASE_USER=educore
DATABASE_PASSWORD=educore
DATABASE_URL=postgres://educore:educore@localhost:5432/educore

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="EduCore <no-reply@educore.local>"

STORAGE_PROVIDER=local
STORAGE_ROOT=/private/tmp/educore-storage
TENANT_HEADER=X-Tenant-Id
PRODUCT_HEADER=X-Product-Code
