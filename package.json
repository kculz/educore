{
  "name": "educore-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace @educore/api",
    "dev:web": "npm run dev --workspace @educore/web",
    "build:api": "npm run build --workspace @educore/api",
